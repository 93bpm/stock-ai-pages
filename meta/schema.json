    "generatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "생성 시각 (ISO 8601 + KST offset)"
    },
    "us": { "$ref": "#/$defs/UsBlock" },
    "world": { "$ref": "#/$defs/WorldBlock" },
    "kr": { "$ref": "#/$defs/KrBlock" },
    "calendar": { "$ref": "#/$defs/CalendarBlock" },
    "calendarWeek": { "$ref": "#/$defs/CalendarWeek" },
    "calendarMonth": { "$ref": "#/$defs/CalendarMonth" }
  },

