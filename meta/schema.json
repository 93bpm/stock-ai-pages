{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://93bpm.github.io/stock-ai-pages/meta/schema.json",
  "title": "Daily Market Briefing",
  "description": "stock-ai-pages 일일 브리핑 데이터 (briefing/YYYY-MM-DD.json)",
  "type": "object",
  "required": ["date", "weekday", "us", "world", "kr", "calendar"],
  "additionalProperties": false,
  "properties": {
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "KST 기준 ISO 날짜 (YYYY-MM-DD)"
