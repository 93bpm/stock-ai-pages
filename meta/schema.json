  "$defs": {

    "Direction": {
      "type": "string",
      "enum": ["up", "down", "neutral"],
      "description": "색상/화살표 결정용. up=빨강(상승), down=파랑(하락), neutral=무채색"
    },

    "NewsItem": {
      "type": "object",
      "required": ["rank", "category", "categoryStyle", "sentiment", "title", "summary", "source", "note"],
      "additionalProperties": false,
      "properties": {
        "rank": { "type": "string", "pattern": "^\\d{2}$", "description": "01~12" },
        "category": {
          "type": "string",
          "description": "자유 텍스트. Claude가 뉴스 내용 보고 정함. 예: 통화정책, 지정학, 반도체, 2차전지, 바이오, 조선·방산, 엔터·콘텐츠, 거시, 정책, 환율, 수급, 기업, 원자재, 코스닥, 증시제도 등"
        },
        "categoryStyle": {
          "type": "string",
          "enum": ["default", "geo", "tech"],
          "description": "category 라벨의 색상 분류. default=파랑(통화정책/거시/정책/환율/수급/기업 등 일반), geo=빨강(지정학/원자재/갈등/관세 등 리스크), tech=초록(반도체/2차전지/바이오/엔터·콘텐츠/조선·방산/AI/기술 등 산업·테마)"
        },
        "sentiment": {
          "type": "string",
          "enum": ["pos", "neg", "neu"],
          "description": "호악재 판단. pos=호재(빨강), neg=악재(파랑), neu=중립(회색). 한국 증시 관행에 따라 상승=빨강, 하락=파랑"
        },
        "title": { "type": "string", "description": "헤드라인" },
        "summary": { "type": "string", "description": "1-2문장 요약 (~돼요/~예요 어미)" },
        "source": { "type": "string", "description": "출처명 (예: Reuters, 연합뉴스)" },
        "sourceUrl": { "type": "string", "format": "uri", "description": "원본 기사 URL (선택). 있으면 헤드라인·출처가 클릭 가능 링크로 렌더링됨" },
        "note": { "type": "string", "description": "왜 중요한지 한 줄 (📖 정리 옆 텍스트)" }
      }
    },

    "Index": {
      "type": "object",
      "required": ["name", "value", "change", "dir"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "description": "지수명 (예: S&P 500, 코스피)" },
        "tip": { "type": "string", "description": "보조 설명 (예: 정규장 종가 · KRX)" },
        "value": { "type": "string", "description": "포맷된 값 (예: 5,842.31 / 2,7xx.x)" },
        "change": { "type": "string", "description": "포맷된 변화율 (예: ▲ 0.61%)" },
        "dir": { "$ref": "#/$defs/Direction" }
      }
    },

    "Indicator": {
      "type": "object",
      "required": ["key", "value"],
      "additionalProperties": false,
      "properties": {
        "key": { "type": "string", "description": "지표명 (예: VIX, 美 10년물)" },
        "value": { "type": "string", "description": "포맷된 값 (예: 13.4 ▼, 4.18%)" },
        "dir": { "$ref": "#/$defs/Direction" }
      }
    },

    "SectorMove": {
      "type": "object",
      "required": ["name", "change"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "change": { "type": "string", "description": "예: +1.8% / −0.6%" }
      }
    },

    "KrSectorTheme": {
      "type": "object",
      "required": ["theme", "stockName", "stockChange"],
      "additionalProperties": false,
      "properties": {
        "theme": { "type": "string", "description": "테마/섹터 라벨 (예: 반도체, 2차전지, 바이오, 자동차, 조선·방산)" },
        "stockName": { "type": "string", "description": "테마의 대표 종목명 (예: 삼성전자, 에코프로, HD현대중공업)" },
        "stockChange": { "type": "string", "description": "대표 종목 일간 등락률 (예: +2.1%, −0.8%, +5.3%)" }
      }
    },

    "UsBlock": {
      "type": "object",
      "required": ["subNote", "comment", "indices", "indicators", "sectorsUp", "sectorsDown"],
      "additionalProperties": false,
      "properties": {
        "subNote": { "type": "string", "description": "섹션 노트 한 줄" },
        "subNoteEm": { "type": "string", "description": "섹션 핵심 헤드라인 한 줄. subNote의 부분문자열이면 inline 강조, 아니면 독립 헤드라인으로 분리 표시 (둘 다 허용 — v1.6.0)" },
        "comment": { "type": "string", "description": "💬 한줄평" },
        "indices": {
          "type": "array",
          "items": { "$ref": "#/$defs/Index" },
          "minItems": 4,
          "maxItems": 4,
          "description": "S&P 500, 나스닥, 다우, 필라델피아 반도체 순"
        },
        "indicators": {
          "type": "array",
          "items": { "$ref": "#/$defs/Indicator" },
          "minItems": 6,
          "maxItems": 6,
          "description": "VIX, 美 10년물, 달러인덱스, WTI 유가, 금, 비트코인 순"
        },
        "sectorsUp": {
          "type": "array",
          "items": { "$ref": "#/$defs/SectorMove" },
          "minItems": 5,
          "maxItems": 5
        },
        "sectorsDown": {
          "type": "array",
          "items": { "$ref": "#/$defs/SectorMove" },
          "minItems": 5,
          "maxItems": 5
        }
      }
    },

    "WorldBlock": {
      "type": "object",
      "required": ["subNote", "global", "domestic"],
      "additionalProperties": false,
      "properties": {
        "subNote": { "type": "string" },
        "subNoteEm": { "type": "string", "description": "섹션 핵심 헤드라인 한 줄 (subNote와 별개 가능 — v1.6.0)" },
        "global": {
          "type": "array",
          "items": { "$ref": "#/$defs/NewsItem" },
          "minItems": 12,
          "maxItems": 12
        },
        "domestic": {
          "type": "array",
          "items": { "$ref": "#/$defs/NewsItem" },
          "minItems": 12,
          "maxItems": 12
        }
      }
    },

    "FlowItem": {
      "type": "object",
      "required": ["key", "value", "dir"],
      "additionalProperties": false,
      "properties": {
        "key": { "type": "string", "description": "예: 원/달러 환율, 야간 선물, 미국 상장 한국물(ADR)" },
        "value": { "type": "string" },
        "dir": { "$ref": "#/$defs/Direction" }
      }
    },

    "SupplyItem": {
      "type": "object",
      "required": ["who", "amount", "dir"],
      "additionalProperties": false,
      "properties": {
        "who": { "type": "string", "description": "외국인, 기관, 개인, 프로그램 (차익+비차익)" },
        "amount": { "type": "string", "description": "실값 (예: +3,245). 마스킹(+3,2xx) 금지 — 추출 실패 시 supply 배열에서 항목 제거" },
        "dir": {
          "type": "string",
          "enum": ["buy", "sell"],
          "description": "buy=빨강(순매수), sell=파랑(순매도)"
        }
      }
    },

    "WatchItem": {
      "type": "object",
      "required": ["name", "badge", "desc"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "description": "종목/섹터명" },
        "badge": { "type": "string", "description": "예: 관심 / 주의" },
        "badgeType": {
          "type": "string",
          "enum": ["up", "down", "default"],
          "description": "up=빨강(상승), down=파랑(하락), default=파랑(중립/주의). 화면은 up만 빨강, down·default는 파랑 (한국 관습: 상승=빨강·하락=파랑) — v1.6.1"
        },
        "desc": { "type": "string" }
      }
    },

    "HealthItem": {
      "type": "object",
      "required": ["key", "value"],
      "additionalProperties": false,
      "properties": {
        "key": { "type": "string", "description": "예: 투자자 예탁금" },
        "tip": { "type": "string", "description": "보조 설명 (예: 대기 자금)" },
        "value": { "type": "string", "description": "실값 (예: 58.7조 / 2조 1,420억). 마스킹(5x.x조) 금지 — 추출 실패 시 health 배열에서 항목 제거" },
        "subIcon": { "type": "string", "description": "값 옆 작은 표시 (예: ▲ / ± / ▼)" },
        "subDir": { "$ref": "#/$defs/Direction" }
      }
    },

    "KrBlock": {
      "type": "object",
      "required": ["subNote", "comment", "expectedRange", "indices", "flow", "supply", "sectorsUp", "sectorsDown", "watchlist", "health"],
      "additionalProperties": false,
      "properties": {
        "subNote": { "type": "string" },
        "subNoteEm": { "type": "string", "description": "섹션 핵심 헤드라인 한 줄 (subNote와 별개 가능 — v1.6.0)" },
        "comment": { "type": "string", "description": "💬 한줄평 (HTML 강조 가능)" },
        "expectedRange": { "type": "string", "description": "예: 코스피 +0.2% ~ +0.8% 부근" },
        "indices": {
          "type": "array",
          "items": { "$ref": "#/$defs/Index" },
          "minItems": 2,
          "maxItems": 2,
          "description": "코스피, 코스닥 순"
        },
        "flow": {
          "type": "array",
          "items": { "$ref": "#/$defs/FlowItem" },
          "minItems": 2,
          "maxItems": 3,
          "description": "원/달러 환율, 야간 선물, 미국 상장 한국물(ADR) 순. 주말·휴장으로 야간선물/ADR을 못 구하면 해당 항목 제외 가능 (2~3개) — v1.6.1"
        },
        "supply": {
          "type": "array",
          "items": { "$ref": "#/$defs/SupplyItem" },
          "minItems": 3,
          "maxItems": 3,
          "description": "외국인, 기관, 개인 순 (3주체). 프로그램 매매는 출처 한계로 v1에서 제외"
        },
        "sectorsUp": {
          "type": "array",
          "items": { "$ref": "#/$defs/KrSectorTheme" },
          "minItems": 5,
          "maxItems": 5,
          "description": "테마/섹터 강세 TOP 5 (대표 종목 + 등락률 형식)"
        },
        "sectorsDown": {
          "type": "array",
          "items": { "$ref": "#/$defs/KrSectorTheme" },
          "minItems": 5,
          "maxItems": 5,
          "description": "테마/섹터 약세 TOP 5 (대표 종목 + 등락률 형식)"
        },
        "watchlist": {
          "type": "array",
          "items": { "$ref": "#/$defs/WatchItem" },
          "minItems": 2,
          "maxItems": 5
        },
        "health": {
          "type": "array",
          "items": { "$ref": "#/$defs/HealthItem" },
          "minItems": 2,
          "maxItems": 3,
          "description": "투자자 예탁금, 신용융자 잔고 (필수 2개) + 공매도 잔고 상위 (선택 — 값 못 찾으면 제거)"
        }
      }
    },

    "TimedEvent": {
      "type": "object",
      "required": ["time", "event"],
      "additionalProperties": false,
      "properties": {
        "time": { "type": "string", "pattern": "^\\d{2}:\\d{2}$", "description": "KST 24h 형식" },
        "event": { "type": "string" },
        "important": { "type": "boolean", "default": false, "description": "true면 '중요' 배지 표시" }
      }
    },

    "UntimedEvent": {
      "type": "object",
      "required": ["event", "when"],
      "additionalProperties": false,
      "properties": {
        "event": { "type": "string" },
        "when": { "type": "string", "description": "예: 장 마감 후 / 미정 / 새벽 ~05시 전후" }
      }
    },

    "ScheduleSide": {
      "type": "object",
      "required": ["timed", "untimed"],
      "additionalProperties": false,
      "properties": {
        "timed": { "type": "array", "items": { "$ref": "#/$defs/TimedEvent" } },
        "untimed": { "type": "array", "items": { "$ref": "#/$defs/UntimedEvent" } }
      }
    },

    "CalendarBlock": {
      "type": "object",
      "required": ["subNote", "riskSentiment", "domestic", "global", "theme", "checks"],
      "additionalProperties": false,
      "properties": {
        "subNote": { "type": "string" },
        "subNoteEm": { "type": "string", "description": "섹션 핵심 헤드라인 한 줄 (subNote와 별개 가능 — v1.6.0)" },
        "riskSentiment": { "type": "string", "description": "예: 위험선호 우위 / 위험회피 / 혼조" },
        "domestic": { "$ref": "#/$defs/ScheduleSide" },
        "global": { "$ref": "#/$defs/ScheduleSide" },
        "theme": { "type": "string", "description": "오늘의 테마 (1-2문장)" },
        "checks": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 3,
          "maxItems": 5,
          "description": "체크리스트 항목"
        }
      }
    },

    "CalEventBase": {
      "type": "object",
      "required": ["region", "event"],
      "additionalProperties": false,
      "properties": {
        "region": { "type": "string", "enum": ["domestic", "global"], "description": "domestic=국내, global=해외" },
        "time": { "type": ["string", "null"], "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$", "description": "KST 시:분 (예: 21:30). 시간 미정이면 null" },
        "event": { "type": "string", "description": "일정 제목" },
        "important": { "type": "boolean", "default": false },
        "category": { "type": "string", "enum": ["earnings", "policy", "macro", "conference", "holiday", "market", "industry"], "description": "earnings=실적, policy=금리/통화정책, macro=경제지표, conference=학회·컨퍼런스·제품발표(WWDC/GTC/Google I/O 등), holiday=증시 휴장, market=증시 이벤트(MSCI 리밸런싱·선물옵션 만기·거래 재개), industry=산업 일반 이벤트. ※ 명명된 학회·제품발표는 conference 우선 (v1.6.0)" }
      }
    },

    "WeekDay": {
      "type": "object",
      "required": ["date", "weekday", "items"],
      "additionalProperties": false,
      "properties": {
        "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "weekday": { "type": "string", "enum": ["일", "월", "화", "수", "목", "금", "토"] },
        "items": { "type": "array", "items": { "$ref": "#/$defs/CalEventBase" } }
      }
    },

    "CalendarWeek": {
      "type": "object",
      "required": ["start", "end", "days"],
      "additionalProperties": false,
      "description": "v1.5.0 신설 — 이번 주 일~토 7일 일정. 빈 날도 items:[] 로 포함",
      "properties": {
        "start": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$", "description": "주의 일요일 (KST)" },
        "end": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$", "description": "주의 토요일 (KST)" },
        "days": {
          "type": "array",
          "minItems": 7,
          "maxItems": 7,
          "items": { "$ref": "#/$defs/WeekDay" }
        }
      }
    },

    "MonthDay": {
      "type": "object",
      "required": ["date", "items"],
      "additionalProperties": false,
      "properties": {
        "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "items": { "type": "array", "items": { "$ref": "#/$defs/CalEventBase" } }
      }
    },

    "CalendarMonth": {
      "type": "object",
      "required": ["year", "month", "days"],
      "additionalProperties": false,
      "description": "v1.5.0 신설 — 이번 달 일정. hit 만 days[] 에 push (빈 날 생략). 월간은 time 미저장",
      "properties": {
        "year": { "type": "integer", "minimum": 2024, "maximum": 2099 },
        "month": { "type": "integer", "minimum": 1, "maximum": 12 },
        "days": {
          "type": "array",
          "items": { "$ref": "#/$defs/MonthDay" }
        }
      }
    }
  }
}
